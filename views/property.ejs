  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
    crossorigin="anonymous"></script>

  <script>
    fetch("http://localhost:3000/allproperty")
      .then((response) => {
        return response.json();
      })
      .then((values) => {
        const Owner_number = localStorage.getItem("Owner_no");
        const item = values.filter(function (item) {
          return item.Owner_no == Owner_number;
        });

        console.log(item[0]);
        const ID = item[0];

        data1 = `   <div class="row" 
        style="position: relative;
                left: 9rem;
            margin-top: -3rem;">
          <div
            class="col col-lg-9 col-md-6 col-sm-12 col-xl-9"
            style="
              border: 2px solid black;
              display: flex;
              flex-direction: column;
              border-radius: 5px;
              justify-content: center;
              align-items: center;
              flex-wrap: nowrap;
            "
          >
            <img
              src="${ID.Property_image}"
              style="width: 70%;
                position: relative;
                display: flex;
                border-radius: 30px
                height: 90%;
                padding: 5px 0 5px 0;
              "
              alt=""
            />
            <div class="tablesData" style="width: -webkit-fill-available;">
              <table class="table table-borderless">
                <thead>
                  <tr>
                    <th scope="col" style="width: 7rem;">Owner No.</th>
                    <th scope="col" style="width: 7rem;">Type</th>
                    <th scope="col" style="width: 7rem;">Loaction</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td style="width: 7rem;">${ID.Owner_no}</td>
                    <td style="width: 7rem;">${ID.Property_type}</td>
                    <td style="width: 7rem;">${ID.Property_location}</td>
                  </tr>
                </tbody>
              </table>

              <table class="table table-borderless">
                <thead>
                  <tr>
                    <th scope="col" style="width: 7rem;">Price</th>
                    <th scope="col" style="width: 7rem;">Owner Email</th>
                    <th scope="col" style="width: 7rem;">Descriptions</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td style="width: 7rem;">${ID.Property_price}</td>
                    <td><a href="mailto:${ID.Owner_email}">${ID.Owner_email}</a> </td>                                                          
                    <td style="width: 7rem;">${ID.Property_discribe}</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>`;
        document.getElementById("container").innerHTML = data1
      })
  </script>
</body>
</html>